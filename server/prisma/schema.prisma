generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RawData {
  id                Int      @id @default(autoincrement())
  channel           String
  recordDate        DateTime @map("record_date")
  campaignId        String   @map("campaign_id")
  campaignName      String?  @map("campaign_name")
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  cost              Float    @default(0)
  downloads         Int      @default(0)
  activations       Int      @default(0)
  formalActivations Int      @default(0) @map("formal_activations")
  leads             Int      @default(0) @map("leads")
  accounts          Int      @default(0)
  ctr               Float    @default(0) @map("ctr")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([channel, recordDate, campaignId], name: "unique_channel_date_campaign")
  @@index([channel])
  @@index([recordDate])
  @@index([campaignId])
  @@index([channel, recordDate])
  @@map("raw_data")
}

model UploadLog {
  id             Int      @id @default(autoincrement())
  filename       String
  recordCount    Int      @default(0) @map("record_count")
  insertedCount  Int      @default(0) @map("inserted_count")
  updatedCount   Int      @default(0) @map("updated_count")
  failedCount    Int      @default(0) @map("failed_count")
  errorDetails   String?  @map("error_details")
  uploadedBy     String?  @map("uploaded_by")
  uploadedAt     DateTime @default(now()) @map("uploaded_at")

  @@index([uploadedAt])
  @@map("upload_logs")
}

model ChannelMapping {
  id            Int      @id @default(autoincrement())
  sourceName    String   @map("source_name")
  targetName    String   @map("target_name")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([sourceName], name: "unique_source_name")
  @@map("channel_mappings")
}

model MerchantData {
  id            Int       @id @default(autoincrement())
  userId        String    @unique @map("user_id")
  qsId          String    @map("qs_id")
  channel       String
  leadDate      DateTime  @map("lead_date")
  accountDate   DateTime? @map("account_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([qsId])
  @@index([channel])
  @@index([leadDate])
  @@index([qsId, leadDate])
  @@index([channel, leadDate])
  @@map("merchant_data")
}

model MerchantMapping {
  id            Int      @id @default(autoincrement())
  qsId          String   @unique @map("qs_id")
  merchantName  String   @map("merchant_name")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("merchant_mappings")
}
